# E-Commerce AI Studio - Environment Configuration
# Copy this file to .env and fill in your values

# ===== Database =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecom_ai_studio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== MinIO / S3 =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ecom-assets
MINIO_SECURE=false

# ===== LLM Aggregation Platform (e.g. Tokenpony / OpenRouter) =====
LLM_API_BASE=https://api.tokenpony.com/v1
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=claude-sonnet-4-6
# Default cheap model for simple tasks (classification, quality check)
LLM_MODEL_CHEAP=gpt-4o-mini

# ===== Image Generation APIs =====
# Flux (via Replicate or Fal.ai)
FLUX_API_KEY=your-flux-api-key-here
FLUX_API_BASE=https://api.replicate.com/v1

# DALL·E 3 (via OpenAI)
OPENAI_API_KEY=your-openai-api-key-here

# Tongyi Wanxiang (via Alibaba DashScope)
TONGYI_API_KEY=your-tongyi-api-key-here

# Stable Diffusion (via Replicate)
REPLICATE_API_KEY=your-replicate-api-key-here

# ===== Video Generation APIs =====
# Runway Gen-3
RUNWAY_API_KEY=your-runway-api-key-here

# Kling (可灵)
KLING_API_KEY=your-kling-api-key-here
KLING_API_SECRET=your-kling-api-secret-here

# Luma Dream Machine
LUMA_API_KEY=your-luma-api-key-here

# ===== JWT =====
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===== App =====
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Celery =====
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
